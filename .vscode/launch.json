{
    "version": "0.2.0",
    "configurations": [
        // ─── Server ───────────────────────────────────────────────
        {
            "name": "Server",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["main:app", "--host", "0.0.0.0", "--port", "8080"],
            "cwd": "${workspaceFolder}/apps/server",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Server (reload)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["main:app", "--host", "0.0.0.0", "--port", "8080", "--reload"],
            "cwd": "${workspaceFolder}/apps/server",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        // ─── Mobile ───────────────────────────────────────────────
        {
            "name": "Mobile",
            "cwd": "apps/mobile",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "Mobile (profile)",
            "cwd": "apps/mobile",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "Mobile (release)",
            "cwd": "apps/mobile",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        // ─── Desktop ──────────────────────────────────────────────
        {
            "name": "Desktop",
            "cwd": "apps/desktop",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "Desktop (profile)",
            "cwd": "apps/desktop",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "Desktop (release)",
            "cwd": "apps/desktop",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        // ─── Demo (design prototype) ──────────────────────────────
        {
            "name": "Demo (design prototype)",
            "type": "debugpy",
            "request": "launch",
            "module": "http.server",
            "args": ["8765"],
            "cwd": "${workspaceFolder}/docs/11_design/desktop_prototype",
            "console": "integratedTerminal",
            "justMyCode": true,
            "serverReadyAction": {
                "pattern": "Serving HTTP on .* port (\\d+)",
                "uriFormat": "http://localhost:%s/Fluxora%%20Desktop.html",
                "action": "openExternally"
            }
        },
        // ─── Web Landing (Next.js) ────────────────────────────────
        {
            "name": "Web Landing (dev)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "cwd": "${workspaceFolder}/apps/web_landing",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "serverReadyAction": {
                "pattern": "(?:- Local:|Ready in|Local:)\\s+https?://[^:]+:(\\d+)",
                "uriFormat": "http://localhost:%s",
                "action": "openExternally"
            }
        },
        {
            "name": "Web Landing (static export preview)",
            "type": "debugpy",
            "request": "launch",
            "module": "http.server",
            "args": ["8766"],
            "cwd": "${workspaceFolder}/apps/web_landing/out",
            "console": "integratedTerminal",
            "justMyCode": true,
            "preLaunchTask": "web-landing-build",
            "serverReadyAction": {
                "pattern": "Serving HTTP on .* port (\\d+)",
                "uriFormat": "http://localhost:%s/",
                "action": "openExternally"
            }
        }
    ],
    "compounds": [
        {
            "name": "Server + Mobile",
            "configurations": ["Server", "Mobile"],
            "stopAll": true
        },
        {
            "name": "Server + Desktop",
            "configurations": ["Server", "Desktop"],
            "stopAll": true
        }
    ]
}
