# Fluxora server environment variables
# Copy this file's structure to ~/.fluxora/.env and fill in real values.
# Never commit the real .env file.

# Required — generate once with: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_HMAC_KEY=

# Optional — from https://www.themoviedb.org/settings/api
# Server degrades gracefully if absent (no metadata enrichment)
TMDB_API_KEY=

# Optional — defaults to 8080
SERVER_PORT=8080

# Optional — "dev" or "prod" (affects log format: plain text vs structured JSON)
ENV=dev
