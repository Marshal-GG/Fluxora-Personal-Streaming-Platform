# Fluxora server environment variables
# Copy this file's structure to ~/.fluxora/.env and fill in real values.
# Never commit the real .env file.
#
# Generate TOKEN_HMAC_KEY once with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# Required — HMAC key for signing bearer tokens
TOKEN_HMAC_KEY=

# Optional server settings (shown with defaults)
FLUXORA_HOST=0.0.0.0
FLUXORA_PORT=8000
FLUXORA_LOG_LEVEL=INFO
FLUXORA_ENV=prod          # "dev" = plain log output, "prod" = structured JSON

# Optional paths (defaults to platform data dir)
# FLUXORA_DB_PATH=~/.fluxora/fluxora.db
# FLUXORA_HLS_TMP=~/.fluxora/hls

# Optional streaming limits
# FLUXORA_MAX_STREAMS=3

# Optional integrations
# FLUXORA_TMDB_KEY=        # from https://www.themoviedb.org/settings/api
# FLUXORA_TURN_URL=
# FLUXORA_TURN_USER=
# FLUXORA_TURN_PASS=
